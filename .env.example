# Resend — used by /api/proposal route to send pre-qualification form emails
# Get the API key from https://resend.com/api-keys
RESEND_API_KEY=

# Optional — defaults to "Pan <hello@pallanca.info>"
# Must be a verified sender on Resend (verify domain pallanca.info there)
RESEND_FROM_ADDRESS=

# Optional — defaults to "pan@piirz.com"
RESEND_TO_ADDRESS=
